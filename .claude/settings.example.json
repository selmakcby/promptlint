{
  "_comment": "Add the hooks below to your existing ~/.claude/settings.json. Don't overwrite — merge the UserPromptSubmit and Stop arrays into your existing 'hooks' object.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/prompt-checker.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/token-reporter.py"
          }
        ]
      }
    ]
  }
}
